{
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "email_subject": {
      "type": "string"
    },
    "executive_summary": {
      "type": "string"
    },
    "competitive_snapshot": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "company": { "type": "string" },
          "post_date": { "type": "string" },
          "content_summary": { "type": "string" },
          "likes": { "type": "number" },
          "comments": { "type": "number" },
          "shares": { "type": "number" },
          "total_engagement": { "type": "number" },
          "url": { "type": "string" }
        },
        "required": [
          "company",
          "post_date",
          "content_summary",
          "likes",
          "comments",
          "shares",
          "total_engagement"
        ]
      }
    },
    "theme_analysis": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "company": { "type": "string" },
          "themes": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["company", "themes"]
      }
    }
  },
  "required": [
    "email_subject",
    "executive_summary",
    "competitive_snapshot",
    "theme_analysis"
